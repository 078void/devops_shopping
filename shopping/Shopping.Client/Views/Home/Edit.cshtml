@model Shopping.Client.Models.Product

@{
    ViewData["Title"] = "編輯產品";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h2 class="mb-0">✏️ 編輯產品</h2>
                </div>
                <div class="card-body">
                    <!-- 顯示錯誤訊息 -->
                    @if (TempData["ErrorMessage"] != null)
                    {
                                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                            <strong>⚠️ 錯誤：</strong> @TempData["ErrorMessage"]
                                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                        </div>
                    }
                    
                    <!-- 顯示模型驗證摘要 -->
                    @if (!ViewData.ModelState.IsValid)
                    {
                                        <div class="alert alert-warning alert-dismissible fade show" role="alert">
                                            <strong>⚠️ 請修正以下錯誤：</strong>
                                            <ul class="mb-0 mt-2">
                                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                                {
                                                                    <li>@error.ErrorMessage</li>
                                                }
                                            </ul>
                                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                        </div>
                    }
                    
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        
                        <!-- 隱藏的 ID 欄位 -->
                        <input type="hidden" asp-for="Id" />
                        <!-- 隱藏欄位：儲存原始圖片 URL -->
                        <input type="hidden" id="originalImageUrl" value="@Model.ImageFile" />
                        <!-- 隱藏欄位：儲存圖片 URL（用於提交表單）-->
                        <input type="hidden" asp-for="ImageFile" id="imageUrl" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">產品名稱 <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Category" class="form-label">產品類別 <span class="text-danger">*</span></label>
                            <select asp-for="Category" class="form-select" required>
                                <option value="">-- 請選擇類別 --</option>
                                <option value="Smart Phone">智慧型手機</option>
                                <option value="Laptop">筆記型電腦</option>
                                <option value="Tablet">平板電腦</option>
                                <option value="White Appliances">白色家電</option>
                                <option value="Electronics">電子產品</option>
                            </select>
                            <span asp-validation-for="Category" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">產品描述</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <!-- 🆕 圖片上傳區塊（支援拖放 + 預覽現有圖片） -->
                        <div class="mb-3">
                            <label class="form-label">產品圖片</label>
                            
                            <!-- 現有圖片預覽（只有當有圖片時才顯示） -->
                            @if (!string.IsNullOrEmpty(Model.ImageFile))
                            {
                                                    <div id="currentImagePreview" class="mb-3">
                                                        <div class="card">
                                                            <div class="card-body">
                                                                <h6 class="card-title">目前圖片：</h6>
                                                                @* 編輯頁：若目前圖片載入失敗，一樣改用前端預設圖片 *@
                                                                <img id="currentImage" src="@Model.ImageFile" alt="目前產品圖片" 
                                                                     class="img-thumbnail" style="max-width: 300px; max-height: 300px;"
                                                                     onerror="this.onerror=null; this.src='/images/default.png';" />
                                                                <div class="mt-2">
                                                                    <button type="button" class="btn btn-sm btn-primary" onclick="showUploadZone()">
                                                                        🔄 更換圖片
                                                                    </button>
                                                                    <button type="button" class="btn btn-sm btn-danger" onclick="removeCurrentImage()">
                                                                        🗑️ 移除圖片
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                            }
                            else
                            {
                                                    <div class="alert alert-info">
                                                        <small>💡 目前沒有圖片，您可以選擇上傳一張圖片</small>
                                                    </div>
                            }
                            
                            <!-- 拖放上傳區域 -->
                            <div id="dropZone" class="drop-zone" style="@(!string.IsNullOrEmpty(Model.ImageFile) ? "display: none;" : "")" 
                                 onclick="document.getElementById('imageFile').click()">
                                <div class="drop-zone-content">
                                    <i class="bi bi-cloud-upload" style="font-size: 3rem; color: #6c757d;"></i>
                                    <p class="mt-2 mb-1"><strong>點擊選擇圖片</strong> 或 拖放圖片到這裡</p>
                                    <small class="text-muted">支援 JPG、PNG、GIF 等格式，最大 5MB</small>
                                </div>
                            </div>
                            
                            <!-- 隱藏的文件輸入 -->
                            <input type="file" name="imageFile" id="imageFile" style="display: none;" accept="image/*" onchange="previewNewImage(event)" />
                            
                            <!-- 新圖片預覽 -->
                            <div id="newImagePreview" class="mt-3" style="display: none;">
                                <div class="card border-success">
                                    <div class="card-body">
                                        <h6 class="card-title text-success">新圖片預覽：</h6>
                                        <img id="newPreview" src="#" alt="新圖片預覽" class="img-thumbnail" style="max-width: 300px; max-height: 300px;" />
                                        <div class="mt-2">
                                            <button type="button" class="btn btn-sm btn-danger" onclick="cancelNewImage()">
                                                🗑️ 取消更換
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label">價格 (NT$) <span class="text-danger">*</span></label>
                            <input asp-for="Price" type="number" step="0.01" min="0.01" class="form-control" required />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <div class="alert alert-info">
                            <strong>📝 提示：</strong> 修改完成後請記得儲存變更
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary">
                                ↩️ 取消
                            </a>
                            <button type="submit" class="btn btn-warning text-dark">
                                💾 儲存變更
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
                                <style>
                                    /* 拖放區域樣式 */
                                    .drop-zone {
                                        border: 3px dashed #dee2e6;
                                        border-radius: 8px;
                                        padding: 40px;
                                        text-align: center;
                                        cursor: pointer;
                                        transition: all 0.3s ease;
                                        background-color: #f8f9fa;
                                    }
        
                                    .drop-zone:hover {
                                        border-color: #ffc107;
                                        background-color: #fff3cd;
                                    }
        
                                    .drop-zone.dragover {
                                        border-color: #ffc107;
                                        background-color: #fff3cd;
                                        transform: scale(1.02);
                                    }
        
                                    .drop-zone-content {
                                        pointer-events: none;
                                    }
                                </style>
    
                        <script>
                    // 等待 DOM 完全載入後再執行
                    document.addEventListener('DOMContentLoaded', function() {
                        const dropZone = document.getElementById('dropZone');
                        const fileInput = document.getElementById('imageFile');
                        const form = document.querySelector('form');
                        const imageUrl = document.getElementById('imageUrl');
                        const originalImageUrl = document.getElementById('originalImageUrl');
            
                        // 確保元素存在
                        if (!dropZone || !fileInput) {
                            console.error('拖放區域或檔案輸入元素未找到');
                            return;
                        }

                        // 初始化：確保隱藏欄位 imageUrl 的值與原始值一致
                        if (imageUrl && originalImageUrl) {
                            if (!imageUrl.value && originalImageUrl.value) {
                                imageUrl.value = originalImageUrl.value;
                            }
                        }

                        // 表單提交前的驗證檢查（調試用）
                        if (form) {
                            form.addEventListener('submit', function(e) {
                                // 檢查表單是否有效
                                if (!form.checkValidity()) {
                                    // 找出所有無效的欄位
                                    const invalidFields = form.querySelectorAll(':invalid');
                            
                                    e.preventDefault();
                                    e.stopPropagation();
                                    form.classList.add('was-validated');
                            
                                    // 顯示警告訊息
                                    return false;
                                }
                            });
                        }
            
            
                                    // 防止默認的拖放行為
                                    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                                        dropZone.addEventListener(eventName, preventDefaults, false);
                                        document.body.addEventListener(eventName, preventDefaults, false);
                                    });
            
                                    function preventDefaults(e) {
                                        e.preventDefault();
                                        e.stopPropagation();
                                    }
            
                                    // 拖放視覺效果
                                    ['dragenter', 'dragover'].forEach(eventName => {
                                        dropZone.addEventListener(eventName, highlight, false);
                                    });
            
                                    ['dragleave', 'drop'].forEach(eventName => {
                                        dropZone.addEventListener(eventName, unhighlight, false);
                                    });
            
                                    function highlight(e) {
                                        dropZone.classList.add('dragover');
                                    }
            
                                    function unhighlight(e) {
                                        dropZone.classList.remove('dragover');
                                    }
            
                                    // 處理拖放的檔案
                                    dropZone.addEventListener('drop', handleDrop, false);
            
                                    function handleDrop(e) {
                                        const dt = e.dataTransfer;
                                        const files = dt.files;
                
                                        if (files.length > 0) {
                                            fileInput.files = files;
                                            previewNewImage({ target: { files: files } });
                                        }
                                    }
                                });
        
                                // 顯示上傳區域（點擊"更換圖片"時）
                                function showUploadZone() {
                                    const currentImagePreview = document.getElementById('currentImagePreview');
                                    const dropZone = document.getElementById('dropZone');
            
                                    if (currentImagePreview) {
                                        currentImagePreview.style.display = 'none';
                                    }
                                    if (dropZone) {
                                        dropZone.style.display = 'block';
                                    }
                                }
        
                    // 預覽新圖片
                    function previewNewImage(event) {
                        const file = event.target.files[0];
                        if (!file) return;
            
                        // 檢查檔案類型
                        if (!file.type.startsWith('image/')) {
                            alert('請選擇圖片檔案！');
                            return;
                        }
            
                        // 檢查檔案大小（5MB）
                        if (file.size > 5 * 1024 * 1024) {
                            alert('圖片大小不能超過 5MB！');
                            return;
                        }
            
                        const reader = new FileReader();
                        reader.onload = function(e) {
                            const newPreview = document.getElementById('newPreview');
                            const newImagePreview = document.getElementById('newImagePreview');
                            const dropZone = document.getElementById('dropZone');
                            const currentImagePreview = document.getElementById('currentImagePreview');
                
                            if (newPreview) newPreview.src = e.target.result;
                            if (newImagePreview) newImagePreview.style.display = 'block';
                            if (dropZone) dropZone.style.display = 'none';
                            if (currentImagePreview) currentImagePreview.style.display = 'none';
                    
                        };
                        reader.readAsDataURL(file);
                    }
        
                    // 取消更換圖片（恢復顯示原圖或上傳區域）
                    function cancelNewImage() {
                        const imageFile = document.getElementById('imageFile');
                        const newImagePreview = document.getElementById('newImagePreview');
                        const originalImageUrl = document.getElementById('originalImageUrl');
                        const currentImagePreview = document.getElementById('currentImagePreview');
                        const dropZone = document.getElementById('dropZone');
                        const imageUrl = document.getElementById('imageUrl');
            
                        // 清空檔案輸入（不上傳新圖片）
                        if (imageFile) imageFile.value = '';
            
                        // 隱藏新圖片預覽
                        if (newImagePreview) newImagePreview.style.display = 'none';
            
                        // 檢查是否有原始圖片
                        if (originalImageUrl && originalImageUrl.value) {
                            // 有原始圖片，恢復顯示原圖並確保隱藏欄位保持原值
                            if (currentImagePreview) currentImagePreview.style.display = 'block';
                            if (imageUrl) imageUrl.value = originalImageUrl.value; // 恢復原始圖片 URL
                        } else {
                            // 沒有原始圖片，顯示上傳區域
                            if (dropZone) dropZone.style.display = 'block';
                            if (imageUrl) imageUrl.value = ''; // 保持為空
                        }
                    }
        
                    // 移除目前的圖片
                    function removeCurrentImage() {
                        if (!confirm('確定要移除目前的圖片嗎？\n\n提交表單後，此產品將沒有圖片。')) {
                            return;
                        }
                
                        const currentImagePreview = document.getElementById('currentImagePreview');
                        const dropZone = document.getElementById('dropZone');
                        const imageUrl = document.getElementById('imageUrl');
                        const imageFile = document.getElementById('imageFile');
                
                        // 清空圖片 URL（提交表單時會傳送空字串給後端）
                        if (imageUrl) imageUrl.value = '';
                
                        // 清空檔案輸入
                        if (imageFile) imageFile.value = '';
                
                        // 隱藏目前圖片預覽，顯示上傳區域
                        if (currentImagePreview) currentImagePreview.style.display = 'none';
                        if (dropZone) dropZone.style.display = 'block';
                
                    }
                        </script>
}